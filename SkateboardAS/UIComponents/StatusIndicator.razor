<span class="cb-badge @BadgeClass">@Status</span>

@code {
    [Parameter] public string Status { get; set; } = "Offline";

    private string BadgeClass => Status switch
    {
        "Running" => "badge-running",
        "Error"   => "badge-error",
        "Idle"    => "badge-idle",
        _         => "badge-offline"
    };
}
