@page "/warehouse-test"
@rendermode InteractiveServer
@using DefaultNamespace

<h3>Warehouse Test</h3>

<button @onclick="GetInventory">GetInventory</button>

<div>
    <input type="number" @bind="pickTrayId" placeholder="Tray ID" />
    <button @onclick="() => PickItem(pickTrayId)">PickItem</button>
</div>

<div>
    <input type="number" @bind="insertTrayId" placeholder="Tray ID" />
    <input type="text" @bind="insertName" placeholder="Name" />
    <button @onclick="InsertItem">InsertItem</button>
</div>

@if (result != null)
{
    <pre>@result</pre>
}

@if (error != null)
{
    <p style="color:red">@error</p>
}

@code {
    private string? result;
    private string? error;
    private int pickTrayId;
    private int insertTrayId;
    private string insertName = "";

    private async Task GetInventory()
    {
        result = null; error = null;
        try { result = await new WarehouseService().GetInventoryAsync(); }
        catch (Exception ex) { error = ex.Message; }
    }

    private async Task PickItem(int trayId)
    {
        result = null; error = null;
        try { result = await new WarehouseService().PickItemAsync(trayId); }
        catch (Exception ex) { error = ex.Message; }
    }

    private async Task InsertItem()
    {
        result = null; error = null;
        try { result = await new WarehouseService().InsertItemAsync(insertTrayId, insertName); }
        catch (Exception ex) { error = ex.Message; }
    }
}
