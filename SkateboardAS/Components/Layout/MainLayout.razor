@inherits LayoutComponentBase
@inject RoleState RoleState

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4 d-flex align-items-center gap-3">
            <label class="d-flex align-items-center gap-2 mb-0">
                <input type="radio" name="role" checked="@(RoleState.CurrentRole == "Manager")"
                       @onchange='() => RoleState.SetRole("Manager")' />
                Manager
            </label>
            <label class="d-flex align-items-center gap-2 mb-0">
                <input type="radio" name="role" checked="@(RoleState.CurrentRole == "Operator")"
                       @onchange='() => RoleState.SetRole("Operator")' />
                Operator
            </label>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
