@page "/manager/formulas"
@rendermode InteractiveServer
@inject FormulaService FormulaService
@using Shared.Services
@using Shared.Entities

<PageTitle>Formulas</PageTitle>
<h1 class="mb-4">Formula Editor</h1>

<div class="row g-4">
    <div class="col-md-7">
        <h5>Existing Formulas</h5>
        @if (formulas.Count == 0)
        {
            <p class="text-muted">No formulas yet.</p>
        }
        else
        {
            @foreach (var f in formulas)
            {
                <div class="card mb-3">
                    <div class="card-body">
                        <div class="d-flex align-items-start">
                            <div class="flex-grow-1">
                                <strong>@f.Name</strong>
                                <p class="text-muted small mb-1">@f.Description</p>
                                <div class="text-muted small">
                                    Required: @(f.RequiredComponentTypes.Any() ? string.Join(", ", f.RequiredComponentTypes) : "none")
                                </div>
                            </div>
                            <div class="d-flex gap-2">
                                <button class="btn btn-sm btn-outline-secondary" @onclick="() => StartEdit(f)">Edit</button>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => Delete(f.Id)">Delete</button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>

    <div class="col-md-5">
        <div class="card">
            <div class="card-header">@(isEditing ? "Edit Formula" : "New Formula")</div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label">Name</label>
                    <input class="form-control" @bind="editFormula.Name" placeholder="e.g. Standard Board" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Description</label>
                    <textarea class="form-control" rows="2" @bind="editFormula.Description"></textarea>
                </div>
                <div class="mb-3">
                    <label class="form-label">Required Component Types</label>
                    @foreach (var type in componentTypes)
                    {
                        var t = type;
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox"
                                   id="type-@t"
                                   checked="@editFormula.RequiredComponentTypes.Contains(t)"
                                   @onchange="e => ToggleType(t, (bool)e.Value!)" />
                            <label class="form-check-label" for="type-@t">@t</label>
                        </div>
                    }
                </div>
                @if (!string.IsNullOrEmpty(feedback))
                {
                    <div class="alert alert-info py-1 small">@feedback</div>
                }
                <div class="d-flex gap-2">
                    <button class="btn btn-primary flex-grow-1" @onclick="Save">Save</button>
                    @if (isEditing)
                    {
                        <button class="btn btn-outline-secondary" @onclick="CancelEdit">Cancel</button>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private List<Formula> formulas = new();
    private Formula editFormula = new();
    private bool isEditing;
    private string? feedback;

    private static readonly string[] componentTypes = ["AGV", "Warehouse", "AssemblyStation"];

    protected override async Task OnInitializedAsync() => await Refresh();

    private async Task Refresh()
    {
        formulas = (await FormulaService.GetAllAsync()).ToList();
    }

    private void ToggleType(string type, bool add)
    {
        if (add && !editFormula.RequiredComponentTypes.Contains(type))
            editFormula.RequiredComponentTypes.Add(type);
        else if (!add)
            editFormula.RequiredComponentTypes.Remove(type);
    }

    private void StartEdit(Formula f)
    {
        editFormula = new Formula
        {
            Id = f.Id,
            Name = f.Name,
            Description = f.Description,
            RequiredComponentTypes = f.RequiredComponentTypes.ToList()
        };
        isEditing = true;
    }

    private void CancelEdit()
    {
        editFormula = new();
        isEditing = false;
        feedback = null;
    }

    private async Task Save()
    {
        if (string.IsNullOrWhiteSpace(editFormula.Name)) return;

        if (isEditing)
            await FormulaService.UpdateAsync(editFormula);
        else
            await FormulaService.CreateAsync(editFormula);

        feedback = "Saved.";
        editFormula = new();
        isEditing = false;
        await Refresh();
    }

    private async Task Delete(string id)
    {
        await FormulaService.DeleteAsync(id);
        await Refresh();
    }
}
