@page "/manager/employees"
@rendermode InteractiveServer
@inject UserService UserService
@inject ProductionLineService LineService
@inject ApiClient Api
@using Shared.Services
@using Shared.Identity
@using Shared.Entities

<PageTitle>Medarbejdere — SkateboardAS</PageTitle>

<div class="page-header">
    <h1 class="page-title">Medarbejderstyring</h1>
    <p class="page-sub">Administrer operatørkonti og tildel produktionslinjer</p>
</div>

<div class="two-col">
    <!-- Left: Operator List -->
    <div>
        <div class="flex items-center justify-between mb-3">
            <span style="font-size:0.875rem;font-weight:700;text-transform:uppercase;
                         letter-spacing:0.06em;color:var(--muted-fg)">
                Operatører
            </span>
            <span class="cb-badge badge-blue">@users.Count</span>
        </div>

        @if (users.Count == 0)
        {
            <div class="cb-empty">
                <i class="bi bi-people"></i>
                Ingen operatører registreret
            </div>
        }
        else
        {
            @foreach (var u in users)
            {
                <div class="list-item">
                    <div style="width:2.25rem;height:2.25rem;border-radius:50%;background:#dbeafe;
                                color:#2563eb;display:flex;align-items:center;justify-content:center;
                                font-weight:700;font-size:0.9rem;flex-shrink:0">
                        @u.UserName?[..1].ToUpper()
                    </div>

                    <div class="list-item-body">
                        <div class="list-item-title">@u.UserName</div>
                        <div class="list-item-sub">
                            Linjer: @(u.AssignedProductionLineIds.Any()
                                ? string.Join(", ", u.AssignedProductionLineIds
                                    .Select(id => lines.FirstOrDefault(l => l.Id == id)?.Name ?? id))
                                : "ingen")
                        </div>
                    </div>

                    <span class="cb-badge badge-purple">@u.Role</span>

                    <div style="display:flex;flex-direction:column;gap:0.375rem;min-width:10rem">
                        <select class="cb-form-select" style="font-size:0.8rem;padding:0.3rem 0.6rem"
                                @bind="assignLineId">
                            <option value="">— vælg linje —</option>
                            @foreach (var l in lines)
                            {
                                <option value="@l.Id">@l.Name</option>
                            }
                        </select>
                        <div class="flex gap-1">
                            <button class="cb-btn-base cb-btn-primary cb-btn-sm"
                                    style="flex:1"
                                    @onclick="() => Assign(u.Id, assignLineId)"
                                    disabled="@string.IsNullOrEmpty(assignLineId)">
                                Tildel
                            </button>
                            <button class="cb-btn-base cb-btn-outline cb-btn-sm"
                                    @onclick="() => Unassign(u.Id, assignLineId)"
                                    disabled="@string.IsNullOrEmpty(assignLineId)">
                                Fjern
                            </button>
                        </div>
                    </div>
                </div>
            }
        }
    </div>

    <!-- Right: Register Panel -->
    <div class="cb-card">
        <div class="cb-card-header">
            <i class="bi bi-person-plus-fill"></i>
            Registrer ny operatør
        </div>
        <div class="cb-card-body">
            <div class="cb-form-group">
                <label class="cb-form-label">Brugernavn</label>
                <input class="cb-form-control" @bind="newUser.Username"
                       placeholder="f.eks. operator01" />
            </div>
            <div class="cb-form-group">
                <label class="cb-form-label">Adgangskode</label>
                <input class="cb-form-control" type="password" @bind="newUser.Password"
                       placeholder="••••••••" />
            </div>

            @if (!string.IsNullOrEmpty(registerFeedback))
            {
                <div class="cb-feedback @(registerError ? "cb-feedback-error" : "cb-feedback-success")">
                    @registerFeedback
                </div>
            }

            <button class="cb-btn-base cb-btn-primary cb-btn-full mt-3"
                    @onclick="RegisterOperator">
                <i class="bi bi-person-plus"></i>
                Registrer
            </button>
        </div>
    </div>
</div>

@code {
    private List<AppUser> users = new();
    private List<ProductionLine> lines = new();
    private string assignLineId = string.Empty;
    private string? registerFeedback;
    private bool registerError;
    private NewUserModel newUser = new();

    protected override async Task OnInitializedAsync() => await Refresh();

    private async Task Refresh()
    {
        users = (await UserService.GetAllAsync()).ToList();
        lines = (await LineService.GetAllAsync()).ToList();
    }

    private async Task Assign(string userId, string lineId)
    {
        if (string.IsNullOrEmpty(lineId)) return;
        await UserService.AssignToLineAsync(userId, lineId);
        await Refresh();
    }

    private async Task Unassign(string userId, string lineId)
    {
        if (string.IsNullOrEmpty(lineId)) return;
        await UserService.RemoveFromLineAsync(userId, lineId);
        await Refresh();
    }

    private async Task RegisterOperator()
    {
        if (string.IsNullOrWhiteSpace(newUser.Username) || string.IsNullOrWhiteSpace(newUser.Password))
        {
            registerFeedback = "Brugernavn og adgangskode er påkrævet.";
            registerError = true;
            return;
        }

        var response = await Api.PostAsync("api/auth/register", new
        {
            newUser.Username,
            newUser.Password,
            Role = "Operator"
        });

        if (response.IsSuccessStatusCode)
        {
            registerFeedback = $"Operatør '{newUser.Username}' oprettet.";
            registerError = false;
            newUser = new();
            await Refresh();
        }
        else
        {
            registerFeedback = "Registrering mislykkedes. Brugernavnet findes måske allerede.";
            registerError = true;
        }
    }

    private class NewUserModel
    {
        public string Username { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
    }
}
