@page "/manager/production-lines"

<h1>Production Line Editor</h1>
<p>Drag and drop components to compose production lines.</p>

<DragDropZone OnItemDropped="HandleComponentDropped">
    @foreach (var lineId in composedLineIds)
    {
        <span class="component-badge">@lineId</span>
    }
</DragDropZone>

@code {
    private List<string> composedLineIds = new();

    private async Task HandleComponentDropped(string componentId)
    {
        // TODO: Implement - add component to production line
        composedLineIds.Add(componentId);
        await Task.CompletedTask;
    }
}
