@page "/manager/production-lines"
@rendermode InteractiveServer
@inject ProductionLineService LineService
@inject ApiClient Api
@using Shared.Services
@using Shared.Entities

<PageTitle>Produktionslinjer — SkateboardAS</PageTitle>

<div class="page-header">
    <h1 class="page-title">Produktionslinjer</h1>
    <p class="page-sub">Opret og konfigurer produktionslinjer med komponenttildelinger</p>
</div>

<div class="two-col">
    <!-- Left: Lines List -->
    <div>
        <div class="flex items-center justify-between mb-3">
            <span style="font-size:0.875rem;font-weight:700;text-transform:uppercase;
                         letter-spacing:0.06em;color:var(--muted-fg)">
                Eksisterende linjer
            </span>
            <span class="cb-badge badge-blue">@lines.Count</span>
        </div>

        @if (lines.Count == 0)
        {
            <div class="cb-empty">
                <i class="bi bi-diagram-3"></i>
                Ingen produktionslinjer endnu
            </div>
        }
        else
        {
            @foreach (var line in lines)
            {
                <div class="list-item">
                    <div style="width:2.25rem;height:2.25rem;border-radius:var(--radius);
                                background:#dcfce7;color:#16a34a;display:flex;align-items:center;
                                justify-content:center;font-size:1rem;flex-shrink:0">
                        <i class="bi bi-diagram-3"></i>
                    </div>

                    <div class="list-item-body">
                        <div class="list-item-title">@line.Name</div>
                        <div class="list-item-sub">
                            Komponenter: @(line.AssignedComponentIds.Any()
                                ? string.Join(", ", line.AssignedComponentIds)
                                : "ingen")
                        </div>
                    </div>

                    <span class="cb-badge @(line.IsActive ? "badge-active" : "badge-inactive")">
                        @(line.IsActive ? "Aktiv" : "Inaktiv")
                    </span>

                    <div class="list-item-actions">
                        <button class="cb-btn-base cb-btn-outline cb-btn-sm"
                                @onclick="() => StartEdit(line)">
                            <i class="bi bi-pencil"></i>
                        </button>
                        <button class="cb-btn-base cb-btn-outline cb-btn-sm"
                                style="color:#dc2626;border-color:#fca5a5"
                                @onclick="() => DeleteLine(line.Id)">
                            <i class="bi bi-trash"></i>
                        </button>
                    </div>
                </div>
            }
        }
    </div>

    <!-- Right: Form Panel -->
    <div class="cb-card">
        <div class="cb-card-header">
            <i class="bi bi-@(editLine.Id == string.Empty ? "plus-circle" : "pencil")"></i>
            @(editLine.Id == string.Empty ? "Ny produktionslinje" : "Rediger linje")
        </div>
        <div class="cb-card-body">
            <div class="cb-form-group">
                <label class="cb-form-label">Navn</label>
                <input class="cb-form-control" @bind="editLine.Name"
                       placeholder="f.eks. Linje A" />
            </div>

            <div class="cb-form-group">
                <label class="cb-form-label">Tildel komponenter</label>
                @if (!availableComponents.Any())
                {
                    <p class="text-xs text-muted">
                        Ingen komponenter opdaget. Sørg for at plugins er indlæst.
                    </p>
                }
                @foreach (var comp in availableComponents)
                {
                    var compId = comp.Id;
                    <div class="cb-form-check">
                        <input type="checkbox"
                               id="comp-@compId"
                               checked="@editLine.AssignedComponentIds.Contains(compId)"
                               @onchange="e => ToggleComponent(compId, (bool)e.Value!)" />
                        <label for="comp-@compId">
                            @comp.Name
                            <span class="text-xs text-muted">(@comp.Type)</span>
                        </label>
                    </div>
                }
            </div>

            @if (!string.IsNullOrEmpty(feedback))
            {
                <div class="cb-feedback cb-feedback-success">@feedback</div>
            }

            <div class="flex gap-2 mt-3">
                <button class="cb-btn-base cb-btn-primary" style="flex:1" @onclick="SaveLine">
                    <i class="bi bi-floppy"></i> Gem
                </button>
                @if (editLine.Id != string.Empty)
                {
                    <button class="cb-btn-base cb-btn-outline" @onclick="CancelEdit">
                        Annuller
                    </button>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private List<ProductionLine> lines = new();
    private List<ComponentInfo> availableComponents = new();
    private ProductionLine editLine = new() { Id = string.Empty };
    private string? feedback;

    protected override async Task OnInitializedAsync()
    {
        await Refresh();
        availableComponents = await Api.GetAsync<List<ComponentInfo>>("api/components") ?? new();
    }

    private async Task Refresh() => lines = (await LineService.GetAllAsync()).ToList();

    private void ToggleComponent(string compId, bool add)
    {
        if (add && !editLine.AssignedComponentIds.Contains(compId))
            editLine.AssignedComponentIds.Add(compId);
        else if (!add)
            editLine.AssignedComponentIds.Remove(compId);
    }

    private void StartEdit(ProductionLine line)
    {
        editLine = new ProductionLine
        {
            Id = line.Id, Name = line.Name,
            IsActive = line.IsActive,
            AssignedComponentIds = line.AssignedComponentIds.ToList()
        };
        feedback = null;
    }

    private void CancelEdit() { editLine = new() { Id = string.Empty }; feedback = null; }

    private async Task SaveLine()
    {
        if (string.IsNullOrWhiteSpace(editLine.Name)) return;

        if (lines.Any(l => l.Id == editLine.Id))
            await LineService.UpdateAsync(editLine);
        else
        {
            editLine.Id = Guid.NewGuid().ToString();
            await LineService.CreateAsync(editLine);
        }

        feedback = "Gemt.";
        editLine = new() { Id = string.Empty };
        await Refresh();
    }

    private async Task DeleteLine(string id) { await LineService.DeleteAsync(id); await Refresh(); }

    private record ComponentInfo(string Id, string Name, string Type, string Status);
}
