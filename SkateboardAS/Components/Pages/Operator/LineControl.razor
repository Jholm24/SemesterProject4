@page "/operator/lines/{LineId}"
@rendermode InteractiveServer
@inject ApiClient Api
@inject ProductionLineService LineService
@using Shared.Services
@using Shared.Entities

<PageTitle>@(line?.Name ?? "Linjekontrol") — SkateboardAS</PageTitle>

@if (line == null)
{
    <div class="cb-loading"><div class="cb-spinner"></div></div>
}
else
{
    <div class="page-header">
        <div class="flex items-center gap-3">
            <a href="/operator/lines" class="cb-btn-base cb-btn-secondary cb-btn-sm">
                <i class="bi bi-arrow-left"></i> Tilbage
            </a>
            <div>
                <h1 class="page-title" style="margin-bottom:0">@line.Name</h1>
                <div class="flex items-center gap-2 mt-1">
                    <span class="cb-badge @StatusBadge(currentStatus)">@currentStatus</span>
                    <span class="text-xs text-muted">Opdateret @lastUpdated.ToString("HH:mm:ss")</span>
                </div>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(message))
    {
        <div class="cb-feedback @(isError ? "cb-feedback-error" : "cb-feedback-info") mb-3">
            @message
        </div>
    }

    <div class="line-control-layout">
        <!-- Left: Controls -->
        <div>
            <!-- Control buttons -->
            <div class="cb-card mb-3">
                <div class="cb-card-header">
                    <i class="bi bi-toggles"></i> Linjestyring
                </div>
                <div class="cb-card-body">
                    <div class="control-actions">
                        <button class="cb-btn-base cb-btn-success cb-btn-lg"
                                @onclick="StartLine"
                                disabled="@(isBusy || currentStatus == "Running")">
                            <i class="bi bi-play-fill"></i> Start
                        </button>
                        <button class="cb-btn-base cb-btn-warning cb-btn-lg"
                                @onclick="StopLine"
                                disabled="@(isBusy || currentStatus != "Running")">
                            <i class="bi bi-stop-fill"></i> Stop
                        </button>
                        <button class="cb-btn-base cb-btn-secondary"
                                @onclick="RefreshStatus"
                                disabled="@isBusy">
                            <i class="bi bi-arrow-clockwise"></i> Opdater
                        </button>
                    </div>
                </div>
            </div>

            <!-- Production Status -->
            @if (productionStatus != null)
            {
                <div class="cb-card">
                    <div class="cb-card-header">
                        <i class="bi bi-activity"></i> Produktionsstatus
                    </div>
                    <div class="cb-card-body">
                        <table class="status-table">
                            <tr>
                                <td>Aktuelt trin</td>
                                <td>@productionStatus.CurrentStep</td>
                            </tr>
                            <tr>
                                <td>Kører</td>
                                <td>
                                    @if (productionStatus.IsRunning)
                                    {
                                        <span class="cb-badge badge-running">Ja</span>
                                    }
                                    else
                                    {
                                        <span class="cb-badge badge-idle">Nej</span>
                                    }
                                </td>
                            </tr>
                            <tr>
                                <td>Sund</td>
                                <td>
                                    @if (productionStatus.IsHealthy)
                                    {
                                        <span class="cb-badge badge-active">Ja</span>
                                    }
                                    else
                                    {
                                        <span class="cb-badge badge-error">Nej</span>
                                    }
                                </td>
                            </tr>
                            <tr>
                                <td>Opdateret</td>
                                <td>@productionStatus.Timestamp.ToLocalTime().ToString("HH:mm:ss")</td>
                            </tr>
                        </table>
                    </div>
                </div>
            }
        </div>

        <!-- Right: Line Info Card -->
        <div class="cb-card" style="align-self:flex-start">
            <div class="cb-card-header">
                <i class="bi bi-info-circle"></i> Linjeinfo
            </div>
            <div class="cb-card-body">
                <div style="margin-bottom:1rem">
                    <div style="font-size:0.75rem;color:var(--muted-fg);margin-bottom:0.25rem">Navn</div>
                    <div style="font-weight:600">@line.Name</div>
                </div>
                <div style="margin-bottom:1rem">
                    <div style="font-size:0.75rem;color:var(--muted-fg);margin-bottom:0.25rem">Status</div>
                    <span class="cb-badge @(line.IsActive ? "badge-active" : "badge-inactive")">
                        @(line.IsActive ? "Aktiv" : "Inaktiv")
                    </span>
                </div>
                <div>
                    <div style="font-size:0.75rem;color:var(--muted-fg);margin-bottom:0.375rem">
                        Komponenter (@line.AssignedComponentIds.Count)
                    </div>
                    @if (line.AssignedComponentIds.Any())
                    {
                        @foreach (var id in line.AssignedComponentIds)
                        {
                            <div style="font-size:0.8125rem;padding:0.2rem 0;color:#374151">
                                <i class="bi bi-circle-fill"
                                   style="font-size:0.375rem;vertical-align:middle;margin-right:0.375rem;color:#9ca3af"></i>
                                @id
                            </div>
                        }
                    }
                    else
                    {
                        <span class="text-xs text-muted">Ingen komponenter tilknyttet</span>
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string LineId { get; set; } = string.Empty;

    private ProductionLine? line;
    private string currentStatus = "Offline";
    private bool isBusy;
    private bool isError;
    private string? message;
    private ProductionStatusResult? productionStatus;
    private DateTime lastUpdated = DateTime.Now;

    protected override async Task OnInitializedAsync()
    {
        line = await LineService.GetByIdAsync(LineId);
        await RefreshStatus();
    }

    private async Task RefreshStatus()
    {
        isBusy = true;
        productionStatus = await Api.GetAsync<ProductionStatusResult>("api/production/status");
        currentStatus = productionStatus?.IsRunning == true ? "Running"
                      : productionStatus?.IsHealthy == false ? "Error"
                      : "Idle";
        lastUpdated = DateTime.Now;
        isBusy = false;
    }

    private async Task StartLine()
    {
        isBusy = true;
        message = null;
        var response = await Api.PostAsync("api/production/start",
            new { TrayId = LineId, ProcessId = "default" });
        if (response.IsSuccessStatusCode)
        {
            productionStatus = await response.Content.ReadFromJsonAsync<ProductionStatusResult>();
            currentStatus = "Running";
            message = "Produktion startet.";
            isError = false;
        }
        else
        {
            message = "Kunne ikke starte produktion.";
            isError = true;
        }
        lastUpdated = DateTime.Now;
        isBusy = false;
    }

    private async Task StopLine()
    {
        isBusy = true;
        message = null;
        await RefreshStatus();
        currentStatus = "Idle";
        message = "Produktion stoppet.";
        isError = false;
        isBusy = false;
    }

    private static string StatusBadge(string s) => s switch
    {
        "Running" => "badge-running",
        "Error"   => "badge-error",
        "Idle"    => "badge-idle",
        _         => "badge-offline"
    };

    private record ProductionStatusResult(
        string ProductionLineId,
        string CurrentStep,
        bool IsRunning,
        bool IsHealthy,
        DateTime Timestamp);
}
